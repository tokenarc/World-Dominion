rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Players collection: only owner can read/write their own doc
    match /players/{playerId} {
      allow read: if request.auth != null && request.auth.uid == playerId;
      allow write: if request.auth != null && request.auth.uid == playerId;
    }

    // Market listings: anyone can read, only authenticated sellers can write their own
    match /marketListings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }

    // Other collections: adjust as needed
  }
}
