rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Players — own data only ──────────────────────────────
    match /players/{playerId} {
      allow read:  if request.auth != null && request.auth.uid == playerId;
      allow write: if request.auth != null && request.auth.uid == playerId;
    }

    // ── Users — own data only ────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Nations — public read, server write only ─────────────
    match /nations/{nationId} {
      allow read:  if true;
      allow write: if false; // Admin SDK only
    }

    // ── Wars — public read, server write only ────────────────
    match /wars/{warId} {
      allow read:  if true;
      allow write: if false; // Admin SDK only
    }

    // ── Events/Gazette — public read only ────────────────────
    match /events/{eventId} {
      allow read:  if true;
      allow write: if false;
    }

    match /gazette/{gazetteId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Elections — public read only ─────────────────────────
    match /elections/{electionId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Stocks — public read only ────────────────────────────
    match /stocks/{stockId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Market listings — public read, auth create/own edit ──
    match /marketListings/{listingId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    // ── Missions — player reads own only ─────────────────────
    match /dailyMissions/{missionId} {
      allow read:  if request.auth != null
        && resource.data.playerId == request.auth.uid;
      allow write: if false; // Server generates missions
    }

    // ── Transactions — player reads own only ─────────────────
    match /transactions/{txId} {
      allow read:  if request.auth != null
        && resource.data.playerId == request.auth.uid;
      allow write: if false; // Server only
    }

    // ── Crypto transactions — player reads own only ──────────
    match /cryptoTransactions/{txId} {
      allow read:  if request.auth != null
        && resource.data.playerId == request.auth.uid;
      allow write: if false; // Server only
    }

    // ── Withdrawals — player reads own only ──────────────────
    match /withdrawals/{withdrawalId} {
      allow read:  if request.auth != null
        && resource.data.playerId == request.auth.uid;
      allow write: if false; // Server only
    }

    // ── Intel reports — auth read only ───────────────────────
    match /intelReports/{reportId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
